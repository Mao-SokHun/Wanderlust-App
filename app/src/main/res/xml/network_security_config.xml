<?xml version="1.0" encoding="utf-8"?>
<!-- Local dev: USB (127.0.0.1), emulator (10.0.2.2), Wi‑Fi (192.168.x.x) -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
